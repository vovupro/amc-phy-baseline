digraph amc_system_overview {
	bgcolor=white fontname=Arial fontsize=18 label=<<B>Toàn cảnh hệ thống AMC (Adaptive Modulation &amp; Coding)</B><BR/><FONT POINT-SIZE="11" COLOR="#666666">Khung viền XANH ĐẬM = đang xây trong project HIỆN TẠI (baseline PHY) · viền XÁM ĐỨT = giai đoạn AMC sau</FONT><BR/> > labelloc=t nodesep=0.55 rankdir=TB ranksep=0.8
	node [fontname=Arial margin="0.22,0.16" shape=box style="rounded,filled"]
	edge [color="#333333" fontcolor="#1a4f8a" fontname=Arial fontsize=10]
	{
		rank=same
		state [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="11.5"><B>STATE  s  (trạng thái kênh + QoS)</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• SNR profile đa subcarrier: mean/var/min/percentile</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• Doppler / coherence time</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• độ tin cậy CSI (var của SNR ước lượng)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">• QoS: target BLER (~10%), latency budget</FONT></TD></TR></TABLE>> fillcolor="#eef5ff" style="rounded,filled"]
		action [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="11.5"><B>ACTION  a  (chế độ truyền = MCS)</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">modulation {BPSK, QPSK, 16QAM}</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">× code rate {1/2, 2/3, 3/4}</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">× #iter decoder {5, 10, 20}</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">→ bảng MCS thu gọn (~9 mode)</FONT></TD></TR></TABLE>> fillcolor="#eef5ff" style="rounded,filled"]
		obj [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="11.5"><B>OBJECTIVE  (hàm mục tiêu)</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">max throughput hiệu dụng:</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">η = R_code × log<SUB>2</SUB>(M) × (1 − BLER)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">ràng buộc: BLER ≤ target</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">             runtime ≤ budget</FONT></TD></TR></TABLE>> fillcolor="#eef5ff" style="rounded,filled"]
	}
	phy [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="11.5"><B>PHY LINK SIMULATOR  (môi trường mô phỏng)</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">Vào: (channel realization, action a)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">Ra : BER, BLER, throughput, runtime</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10"><I>Project hiện tại: bản single-carrier, perfect CSI,</I></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10"><I>chưa LDPC/OFDM — sẽ nâng cấp ở giai đoạn sau</I></FONT></TD></TR></TABLE>> color="#1a7d1a" fillcolor="#d8f5d0" penwidth=3 style="rounded,filled"]
	subgraph cluster_offline_sinh_nh_n_hu_n_luy_n {
		color="#7a5cc0" fontcolor="#7a5cc0" fontname=Arial fontsize=12 label="OFFLINE — sinh nhãn & huấn luyện" style="rounded,dashed"
		oracle [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="11.5"><B>ORACLE / GENIE (vét cạn)</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">Với mỗi state s: thử MỌI action a qua simulator,</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">đo BLER tin cậy (Monte Carlo ≥ N lỗi),</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">chọn a*(s) = argmax objective</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">→ đây là LUT tối ưu / upper bound</FONT></TD></TR></TABLE>> color="#888888" fillcolor="#e7e0ff" style="rounded,filled,dashed"]
		data [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="11.5"><B>DATASET  {(s, a*)}</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">cặp trạng thái → hành động tối ưu</FONT></TD></TR></TABLE>> color="#888888" fillcolor="#e7e0ff" style="rounded,filled,dashed"]
		mltrain [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="11.5"><B>ML POLICY  π(s)</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">học ánh xạ s → a*</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">= bản NÉN &amp; GENERALIZE của oracle</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">(nhẹ, giải thích được)</FONT></TD></TR></TABLE>> color="#888888" fillcolor="#e7e0ff" style="rounded,filled,dashed"]
	}
	subgraph cluster_online_v_ng_quy_t_nh_runtime {
		color="#d08a2c" fontcolor="#d08a2c" fontname=Arial fontsize=12 label="ONLINE — vòng quyết định runtime" style="rounded,dashed"
		ctrl [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="11.5"><B>BỘ QUYẾT ĐỊNH + HYSTERESIS</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">s_t → π(s_t) → a_candidate</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">Hysteresis: chỉ đổi mode khi vượt ngưỡng &amp; giữ đủ lâu</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">→ a_final (mode phát)</FONT></TD></TR></TABLE>> color="#888888" fillcolor="#ffe3c2" style="rounded,filled,dashed"]
	}
	eval [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="11.5"><B>ĐÁNH GIÁ &amp; SO SÁNH</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">Fixed-robust (BPSK 1/2) · Fixed-high-TP (16QAM 3/4) · AI-adaptive π</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">Sản phẩm: BER vs SNR · Throughput vs SNR ·</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">Runtime/complexity table · Policy map (SNR → mode)</FONT></TD></TR></TABLE>> color="#888888" fillcolor="#fff3c4" style="rounded,filled,dashed"]
	action -> phy [label=a color="#333333"]
	phy -> oracle [label="BER/BLER,
throughput,
runtime" color="#333333"]
	obj -> oracle [label="tiêu chí chọn" color="#7a5cc0" style=dashed]
	state -> oracle [label="duyệt theo s" color="#7a5cc0" style=dashed]
	oracle -> data [label="" color="#333333"]
	data -> mltrain [label="" color="#333333"]
	mltrain -> ctrl [label="π(s)" color="#333333"]
	state -> ctrl [label="s_t đo online" color="#d08a2c" style=dashed]
	ctrl -> eval [label="AI-adaptive a*" color="#d08a2c"]
	phy -> eval [label="đo 3 chính sách" color="#333333"]
	dpi=300
}
